FROM node:20-alpine AS builder

WORKDIR /app

COPY src/frontend-web/package.json src/frontend-web/package-lock.json ./
RUN npm ci

COPY src/frontend-web/ ./
RUN npm run build

FROM nginx:1.27-alpine

RUN addgroup -g 1001 -S appuser && adduser -u 1001 -S appuser -G appuser

COPY --from=builder /app/dist /usr/share/nginx/html
COPY infra/nginx/default.conf /etc/nginx/conf.d/default.conf

RUN chown -R appuser:appuser /var/cache/nginx /var/log/nginx && \
    touch /var/run/nginx.pid && chown appuser:appuser /var/run/nginx.pid

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost:3000/ || exit 1

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
