# Runtime
ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
UI_URL=http://localhost:3000

# Security
JWT_SECRET=replace-with-strong-random-secret
JWT_ACCESS_EXPIRES_MINUTES=30
JWT_REFRESH_EXPIRES_MINUTES=10080

# Database and infra
DATABASE_URL=postgresql+psycopg://notebooklm:notebooklm@localhost:5432/notebooklm
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=notebooklm
RQ_QUEUE_NAME_CORE=notebooklm-core
RQ_QUEUE_NAME_PODCAST=notebooklm-podcast
RQ_STRICT_MODE=true
RQ_WORKER_ROLE=core
RQ_WORKER_QUEUES=
JOB_MAX_RETRIES_INGESTION=2
JOB_MAX_RETRIES_PODCAST=2
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=notebooklm_chunks
EMBEDDING_DIMENSION=768

# LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_PODCAST_TIMEOUT_SECONDS=180
OLLAMA_DISABLE_THINKING=true
OLLAMA_PREWARM_ON_STARTUP=true
OLLAMA_PREWARM_TIMEOUT_SECONDS=30
ENABLE_CROSS_ENCODER_RERANK=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Integrations
ZEP_API_KEY=replace-with-zep-api-key
ZEP_PROJECT_ID=replace-with-zep-project-uuid
ASSEMBLYAI_API_KEY=
FIRECRAWL_API_KEY=

# Optional toggles
ENABLE_AUDIO_PARSING=true
ENABLE_YOUTUBE_PARSING=true
ENABLE_WEB_SCRAPING=true
MAX_UPLOAD_BYTES=52428800
MAX_SOURCES_PER_USER=200
IDEMPOTENCY_TTL_SECONDS=7200
OAUTH_STATE_TTL_SECONDS=600
OAUTH_EXCHANGE_CODE_TTL_SECONDS=180
CORS_ORIGINS=http://localhost:3000

# Podcast TTS
PODCAST_TTS_PROVIDER=kokoro
KOKORO_REPO_ID=hexgrad/Kokoro-82M
KOKORO_SPACY_MODEL=en_core_web_sm
KOKORO_VOICE_HOST=af_heart
KOKORO_VOICE_ANALYST=am_adam
KOKORO_PREWARM_ON_STARTUP=true
PODCAST_CONTEXT_MAX_CHARS=4500
PODCAST_CHUNKS_PER_SOURCE=3
PODCAST_CHUNK_EXCERPT_CHARS=420
PODCAST_TTS_TIMEOUT_SECONDS=600
PODCAST_MIX_TIMEOUT_SECONDS=60
