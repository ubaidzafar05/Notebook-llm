FROM python:3.11-slim AS builder

WORKDIR /app

RUN pip install --no-cache-dir uv==0.6.6

COPY pyproject.toml uv.lock README.md ./
COPY src/backend src/backend
COPY src/frontend src/frontend
COPY alembic alembic
COPY alembic.ini .
COPY scripts scripts

RUN uv sync --no-dev --frozen
RUN .venv/bin/python -m ensurepip && \
    .venv/bin/python -m spacy download en_core_web_sm

FROM python:3.11-slim

RUN groupadd --gid 1001 appuser && \
    useradd --uid 1001 --gid appuser --shell /bin/false appuser

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app/src /app/src
COPY --from=builder /app/alembic /app/alembic
COPY --from=builder /app/alembic.ini /app/alembic.ini
COPY --from=builder /app/scripts /app/scripts
COPY --from=builder /app/pyproject.toml /app/pyproject.toml

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV HOME="/app"
ENV XDG_CACHE_HOME="/app/.cache"
ENV HF_HOME="/app/.cache/huggingface"
ENV TRANSFORMERS_CACHE="/app/.cache/huggingface"

RUN mkdir -p /app/.cache/huggingface /app/outputs/podcasts /app/outputs/uploads /app/data/processed && \
    chown -R appuser:appuser /app/.cache /app/outputs /app/data

USER appuser

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--app-dir", "src/backend", "--host", "0.0.0.0", "--port", "8000"]
